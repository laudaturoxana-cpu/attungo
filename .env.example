# ═══════════════════════════════════════════
# ATTUNGO — Environment Variables Template
# Copiază în .env.local și completează valorile
# NICIODATĂ nu pune .env.local în GitHub!
# ═══════════════════════════════════════════

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Gemini AI (Google)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# Stripe
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Price IDs (creează în Stripe Dashboard > Products)
STRIPE_PRICE_ESSENTIAL_MONTHLY=price_xxx
STRIPE_PRICE_FAMILY_MONTHLY=price_xxx
STRIPE_PRICE_ANNUAL=price_xxx

# FastAPI Backend
BACKEND_URL=http://localhost:8000
BACKEND_SECRET=your_random_secret_at_least_32_chars

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
